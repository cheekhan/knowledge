{
  "name": "knowledge-base",
  "version": "1.0.0",
  "description": "本地优先的综合桌面知识库软件 — Markdown 笔记 + PDF 阅读标注 + 文件级绑定",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "postinstall": "ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ npx @electron/rebuild -f -v 43.1.1 -w better-sqlite3",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm rebuild better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "predev": "npx @electron/rebuild -f -v 43.1.1 -w better-sqlite3",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:win": "pnpm build && electron-builder --win",
    "dist:all": "pnpm build && electron-builder --mac --win",
    "dist:publish": "pnpm build && electron-builder --mac --win --publish always"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "better-sqlite3": "^12.11.0",
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.0",
    "katex": "^0.16.0",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.4.0",
    "pdfjs-dist": "^6.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.0",
    "zod": "^3.24.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/markdown-it": "^14.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.0",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
